NODE_ENV=production
NEXTAUTH_URL=https://reclamos.example.hn
NEXTAUTH_SECRET=
ENABLE_LOCAL_LOGIN=false
NEXT_PUBLIC_ENABLE_LOCAL_LOGIN=false
NEXT_PUBLIC_ENABLE_ENTRA_LOGIN=true

DATABASE_URL=
POSTGRES_DB=cree_reclamos
POSTGRES_SUPERUSER=postgres
APP_DB_USER=cree_app
MIGRATION_DB_USER=cree_migrator

# DATABASE_URL must be provided through ./secrets/database_url.txt in Docker.
# Example format only. Do not paste real credentials here:
# postgresql://cree_app:<password>@postgres:5432/cree_reclamos?schema=public&sslmode=require
# Migration URL must be provided through ./secrets/migration_database_url.txt.
# Example format only:
# postgresql://cree_migrator:<password>@postgres:5432/cree_reclamos?schema=public&sslmode=require

REDIS_URL=redis://redis:6379
PUBLIC_SUBMISSION_RATE_LIMIT=12
LOCAL_LOGIN_RATE_LIMIT=10
IP_HASH_SECRET=

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=cree-client-photos
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_ENABLED=true

AZURE_AD_CLIENT_ID=
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_SECRET=

# Local seed only. Do not commit real values.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
